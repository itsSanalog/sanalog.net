---
import { getEntry, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

const uses = await getEntry("blog", "uses");
const { Content } = await render(uses);
---

<!-- IMPORTANT: this file overwrites /blog/uses that would have been generated by [...slug].astro, or at least i think it does. -->

<BlogLayout title="Uses">
  <content>
    <h1>i use things</h1>
    <p class="muted"><em>..whether i like them or not.</em></p>
    <p>A list of tools I use frequently.</p>
    <Content />
  </content>
</BlogLayout>