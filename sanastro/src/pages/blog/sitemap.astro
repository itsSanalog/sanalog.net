---
import { getEntry } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

const sitemap = await getEntry("blog", "sitemap");
const { Content } = await sitemap.render();
---

<!-- IMPORTANT: this file overwrites /blog/sitemap that would have been generated by [...slug].astro, or at least i think it does. -->

<BlogLayout title="Sitemap">
  <content>
    <h1>sitemap</h1>
    <p class="muted"><em>..mapping pages makes this more of an index.</em></p>
    <p class="mmb">A sitemap of sanaBlog. Work in progress.</p>

    <Content />
  </content>
</BlogLayout>

<script type="module">
  import ForceGraph from 'https://esm.sh/force-graph@1.43.3';

  document.addEventListener('DOMContentLoaded', () => {
    const dataEl = document.getElementById('sitemap-data');
    const container = document.getElementById('graph-container');
    
    if (!dataEl || !container) return;

    const graphData = JSON.parse(dataEl.textContent);
    
    // Theme setup
    const isLightTheme = document.body.classList.contains("theme-light");
    const textColor = 'var(--color-tx-normal)';
    const linkColor = 'var(--color-ui-normal)';
    container.style.backgroundColor ='var(--color-bg-primary)';

    const Graph = ForceGraph()(container)
      .graphData(graphData)
      .nodeId('id')
      .nodeVal('val') // Size nodes based on val (12 for categories, 4 for posts)
      .nodeAutoColorBy('group') // Automatically assigns a persistent color per top-level category
      .linkColor(() => linkColor)
      .linkWidth(1.5)
      .onNodeClick(node => {
        // Click to navigate immediately
        window.location.href = node.url;
      })
      .nodeCanvasObject((node, ctx, globalScale) => {

        const size = node.val;
        const fontSize = 12 / globalScale;
        
        // dots
        ctx.beginPath();
        ctx.arc(node.x, node.y, size, 0, 2 * Math.PI, false);
        ctx.fillStyle = node.color;
        ctx.fill();

        // text
        ctx.font = `${fontSize}px Inter, sans-serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillStyle = textColor;
        ctx.fillText(node.label, node.x, node.y + size + (4 / globalScale));
      });

    // Add some gravity to keep nodes clustered tightly in the center
    Graph.d3Force('charge').strength(-400);
    
    // Minimum distance
    Graph.d3Force('link').distance(80);

    // Experimental
    // Graph.onEngineStop(() => {
    //   Graph.zoomToFit(400, 50);
    // });

    // theme updates (disabled)
    // const themeToggle = document.querySelector("#theme-toggle");
    // if (themeToggle) {
    //   themeToggle.addEventListener("click", () => {
    //     setTimeout(() => window.location.reload(), 100); 
    //   });
    // }
  });
</script>

<style>
  :global(#graph-container canvas) {
    cursor: grab;
  }
  :global(#graph-container canvas:active) {
    cursor: grabbing;
  }
</style>