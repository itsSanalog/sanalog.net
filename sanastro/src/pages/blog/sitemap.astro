---
import { getEntry } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

const sitemap = await getEntry("blog", "sitemap");
const { Content } = await sitemap.render();
---

<!-- IMPORTANT: this file overwrites /blog/sitemap that would have been generated by [...slug].astro, or at least i think it does. -->

<BlogLayout title="Sitemap">
  <content>
    <h1>sitemap</h1>
    <p class="muted"><em>..mapping pages makes this more of an index.</em></p>
    <p class="mmb">A sitemap of sanaBlog. Work in progress.</p>

    <Content />
  </content>
</BlogLayout>

<script type="module">
  import ForceGraph from 'https://esm.sh/force-graph@1.43.3';

  document.addEventListener('DOMContentLoaded', () => {
    const dataEl = document.getElementById('sitemap-data');
    const container = document.getElementById('graph-container');
    
    if (!dataEl || !container) return;
    
    const graphData = JSON.parse(dataEl.textContent);

    // Without this for some reason the canvas itself becomes way bigger than the parent div, and centering is off
    const width = container.clientWidth;
    const height = container.clientHeight;
    
    // Colour setup
    const getCSSVar = (name) => getComputedStyle(container).getPropertyValue(name).trim();
    const textColor = getCSSVar('--color-tx-normal') || '#ff0000';
    const linkColor = getCSSVar('--color-ui-normal') || '#00ff00';
    const bgColor = getCSSVar('--color-bg-primary') || '#0000ff';

    container.style.backgroundColor = bgColor;

    const Graph = ForceGraph()(container)
      .width(width)
      .height(height)
      .graphData(graphData)
      .nodeAutoColorBy('group') // auto color per top-level category
      .linkColor(() => linkColor)
      .linkWidth(2)
      .onNodeClick(node => {
        window.location.href = node.url;
      })
      .nodeCanvasObject((node, ctx, globalScale) => {

        const size = node.val; 
        const fontSize = 10;
        
        // dots
        ctx.beginPath();
        ctx.arc(node.x, node.y, size, 0, 2 * Math.PI, false);
        ctx.fillStyle = node.color;
        ctx.fill();

        // text
        ctx.font = `${fontSize}px Firacode, monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillStyle = textColor;
        ctx.fillText(node.label, node.x, node.y + size + 3);
      });

    // gravity and cluster settings
    Graph.d3Force('charge').strength(-100);
    Graph.d3Force('link').distance(80);

    // theme updates (disabled)
    // const themeToggle = document.querySelector("#theme-toggle");
    // if (themeToggle) {
    //   themeToggle.addEventListener("click", () => {
    //     setTimeout(() => window.location.reload(), 100); 
    //   });
    // }
  });
</script>

<style>
  :global(#graph-container canvas) {
    cursor: grab;
  }
  :global(#graph-container canvas:active) {
    cursor: grabbing;
  }
</style>