---
import "../styles/normalize.css";

import { Image } from 'astro:assets';
import wandanlage from '../assets/wandanlage.jpg';

import Head from "../components/Head.astro";
---

<html lang="en">
  <Head title="About" />
  <body>
    <main class="background-grid">
      <h1 class="main-title">
        <span class="info-node">
          <span class="target-word">I</span>
          <div class="info-elbow elbow-i"></div>
          <div class="info-box box-i">
            <p>I am a jack of all trades regarding technical and creative media. My work processes favour creative and innovative approaches to tasks. This is accompanied by heavy, yet uncluttered documentation with a focus on information delivery and presentation.</p>
          </div>
        </span> 
        love 
        <span class="info-node">
          <span class="target-word">making</span>
          <div class="info-elbow elbow-making"></div>
          <div class="info-box box-making">
            <p>Passionate about web development, computer graphics and visualization, and 3D modelling and rendering. Led multiple projects including multi-platform app development, robotics competitions, and spatial design, as well as solo endeavours in graphic design, web development, and video editing.</p>
          </div>
        </span> 
        <span class="info-node">
          <span class="target-word">stuff</span>.
          <div class="info-elbow elbow-stuff"></div>
          <div class="info-box box-stuff">
            <p>Proficient in programming in various languages and a trilingual individual beyond computers, making me an asset to any global team.</p>
          </div>
        </span>
      </h1>
    </main>

    <div class="music-container">
      <Image src={ wandanlage } alt="wandanlage" class="wandanlage" />

      <div class="text-area">
        <div class="now-playing">
          <div id="status-dot" class="dot"></div>
          <p id="status-text" class="">CONNECTING...</p>
        </div>
        <p id="track-name" class="track-text">—</p>
        <p id="artist-name" class="artist-text">—</p>
        <p class="snacks">TYPE: AUDIO/LP <span>SOURCE: LAST.FM</span><span>REF 00-02</span></p>
        <p class="description" style="margin-top: 2.1cqw">When I am not making something, I am listening to music.</p>
        <p class="description">Music is a great source of inspiration. Music acts a solvent for the millions of ideas <br> making up the whirlpool in my mind. It catalyses the cross-pollination of thoughts.</p>
        <p class="description">I talk about my favourite albums at <a href="https://sanalog.net/blog/reviews/music">sanalog.net/blog/reviews/music</a>.</p>
      </div>

      <div class="album-frame">
        <img src="" alt="" class="album-cover" />
      </div>
    </div>
  </body>
</html>


<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display&display=swap');

  @font-face {
    font-family: 'BritDark';
    src: url('/fonts/britrdn.ttf') format('truetype');
    font-display: swap;
  }

  @font-face {
    font-family: 'Helvetica';
    src: url('/fonts/Helvetica.ttf') format('truetype');
    font-weight: normal;
    font-display: swap;
  }
  
  :root {
    --bg-color: #e7e7e7; 
    --text-color: #222;
    --grid-line: rgba(0, 0, 0, 0.1); 
  }

  ::selection {
    background-color: var(--text-color);
    color: var(--bg-color);
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: 'Playfair Display', serif;
  }
  
  main {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  a {
    color: var(--text-color);
    text-decoration: none;
    border-bottom: 1px solid var(--text-color);
  }

  img {
    display: block;
  }
  
  .background-grid {
    background-size: 5cqw 5cqw;
    background-image:
      linear-gradient(to right, var(--grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-line) 1px, transparent 1px);
    mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
  }

  .main-title {
    font-family: 'Playfair Display';
    font-size: 5cqw;
    font-weight: 400;
    text-align: center;
    margin: 0;
    cursor: crosshair;
  }

  .info-node {
    position: relative;
    display: inline-block;
  }

  .target-word {
    transition: all 0.3s ease;
  }

  .info-box {
    position: absolute;
    background: var(--bg-color);
    border: 1px solid var(--grid-line);

    color: var(--grid-line);
    font-family: 'Playfair Display', serif;
    text-align: left;
    transition: all 0.3s ease;
  }

  .info-box p {
    margin: 0;
    padding: 0.5cqw;
    font-size: 1cqw;
    line-height: 1.2;
  }

  .info-elbow {
    position: absolute;
    border: 0 solid var(--grid-line);
    transition: border-color 0.3s ease;
    pointer-events: none;
  }

  .elbow-i {
    bottom: 50%;
    left: 48%;
    width: 10cqw;
    height: 6cqw;
    border-top-width: 1px;
    border-left-width: 1px;
  }
  .box-i {
    width: 20cqw;
    height: 10cqw;
    bottom: calc(50% + 6cqw);
    left: calc(48% + 10cqw);
  }

  .elbow-making {
    top: 50%;
    right: 54%;
    width: 8cqw;
    height: 12cqw;
    border-bottom-width: 1px;
    border-right-width: 1px;
  }
  .box-making {
    width: 25cqw;
    height: 8cqw;
    top: calc(50% + 8cqw);
    right: calc(54% + 8cqw);
  }

  .elbow-stuff {
    top: 80%;
    left: 55%;
    height: 5cqw;
    border-left-width: 1px;
  }
  .box-stuff {
    width: 20cqw;
    height: 6cqw;
    top: calc(80% + 4cqw);
    left: calc(54% - 10cqw);
  }

  .info-node:hover .target-word {
    /* box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2); */
    text-shadow: 0 0 8px rgba(0, 0, 0, 0.5);
    border-radius: 0.5vw;
  }

  .info-node:hover .info-box,
  .info-node:hover .info-elbow,
  .info-node:hover .info-box::after {  
    border-color: var(--text-color);
    color: var(--text-color);
  }
  


  /* MUSIC STUFF */


  .music-container {
    position: relative;
    width: 100%;
    /* z-index: 1; */
  }

  .wandanlage {
    width: 100%;
    height: auto;
    object-fit: contain;
    pointer-events: none;
    mask-image: linear-gradient(to top, black 92%, transparent 100%);
  }

  .album-cover {
    position: absolute;
    left: 62.7%;
    top: 29.5%;
    width: calc(136% * (300 / 3000));
    height: calc(136% * (300 / 1705));
    /* the reason why two variables are used is because the 136% is scale, while 300 is the original image width. */
    /* in the case of calc(100% * (1000 / 3000)), it's kept that way for consistency. Otherwise calc(100000% / 3000) is fine too. */
    filter: contrast(0.85) saturate(0.85) drop-shadow(0 0 0.8cqw rgba(0, 0, 0, 0.5));
  }

  .text-area {
    position: absolute;
    left: 23%;
    top: 29.5%;
    
    width: calc(100% * (1000 / 3000));
    height: calc(100% * (1000 / 1705));
    /* border: 1px solid #ff00ff; */
    /* this is kept square so that i don't have to use calc() for all its children. */
  }

  .now-playing {
    display: flex;
    align-items: center;
    width: 100%;
    height: 2%;
    gap: 1%;

    font-family: Helvetica, sans-serif;
    font-weight: bold;
    color: #696969;
    font-size: 1cqw;
  }

  /* so .dot needs to be scaled using %, but this doesn't work if now-playing is smallest bounding box, because it'll just be 0. So we use a fixed width/height using % for now-playing as well. */

  .dot {
    position: relative;
    /* top: 12%; */
    width: 2%;
    height: 100%;
    background: #ccc;
    border-radius: 50%;
  }

  .dot.is-live {
    background: #ff2b2b;
    /* box-shadow: 0 0 10px rgba(255, 0, 0, 0.5); */
    animation: passive-pulse 2s infinite;
  }

  .track-text {
    font-family: BritDark;
    font-size: 5cqw;
    line-height: 0.8;
    margin: 1.5cqw 0 0 0;
  }

  .artist-text {
    position: relative;
    font-family: BritDark;
    font-size: 2cqw;
    line-height: 0.8;
    margin: 0.5cqw 0 0 0.1cqw;
  }

  .snacks {
    display: flex;
    justify-content: space-between;
    font-family: Helvetica, sans-serif;
    font-weight: bold;
    font-size: 0.8cqw;
    color: #b4b4b4;
    margin: 2.5cqw 5cqw 0 0.1cqw;
  }

  .description {
    font-family: 'Playfair Display', serif;
    font-size: 0.8cqw;
    line-height: 1.6;
    color: var(--text-color);
    margin: 0.5cqw 0 0 0.1cqw;
  }

  @keyframes passive-pulse {
    0% { transform: scale(1); box-shadow: 0 0 4px rgba(255, 43, 43, 0.4); }
    50% { transform: scale(1.1); box-shadow: 0 0 10px rgba(255, 43, 43, 0.8); }
    100% { transform: scale(1); box-shadow: 0 0 4px rgba(255, 43, 43, 0.4); }
  }
</style>


<script>
  // https://soft.thran.uk/last-played.html
  const API_URL = `https://www.ballix.net/whatsplaying/now?user=sanabeats`;

  async function fetchNowPlaying() {
    try {
      const response = await fetch(API_URL);
      const data = await response.json();

      const trackEl = document.getElementById('track-name');
      const artistEl = document.getElementById('artist-name');
      const statusText = document.getElementById('status-text');
      const statusDot = document.getElementById('status-dot');
      const albumImg = document.querySelector('.album-cover');

      trackEl.textContent = data.name;
      artistEl.textContent = data.artist;
      
      if (data.image) {
        albumImg.src = data.image.extralarge;
      }

      if (data.nowplaying === "true") {
        statusText.textContent = "NOW PLAYING";
        statusDot.classList.add('is-live');
      } else {
        statusText.textContent = "last played: " + data.date;
        statusDot.classList.remove('is-live');
      }

      // load the widget
      // document.getElementById('now-playing-container').style.opacity = "1";

    } catch (error) {
      console.error("oh no what happened", error);
    }
  }

  fetchNowPlaying();
  // refresh every 30 seconds
  setInterval(fetchNowPlaying, 30000);
</script>